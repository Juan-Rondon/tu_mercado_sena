{
  "expo": {
    "name": "MercadoSena",
    "slug": "MercadoSena",
    "version": "1.0.0",
    "orientation": "portrait",
    // "icon": "./assets/images/icon.png",
    "scheme": "mercadosena",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2DC75C",
        "foregroundImage": "./assets/images/logo.png",
        // "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2DC75C",
          "dark": {
            "image": "./assets/images/splash-icon-screen.png",
            "backgroundColor": "#2DC75C"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
