{
  "expo": {
    "name": "Mercado Sena",
    "slug": "mercado-sena",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mercadosena",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.sena.mercadosena",
      "supportsTablet": true
    },
    "android": {
      "package": "com.sena.mercadosena",
      "adaptiveIcon": {
        "backgroundColor": "#2DC75C",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2DC75C",
          "dark": {
            "image": "./assets/images/splash-icon-screen.png",
            "backgroundColor": "#2DC75C"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51d9c065-0871-4b6d-8c9f-0cc2128b4806"
      }
    }
  }
}
